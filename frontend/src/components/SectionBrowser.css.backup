/* Section Browser Modal Styles */

.section-browser-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.section-browser-modal {
  background: white;
  border-radius: 12px;
  width: 90%;
  max-width: 700px;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Header */
.section-browser-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px;
  border-bottom: 1px solid #e5e7eb;
}

.section-browser-header h2 {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0;
  font-size: 20px;
  font-weight: 600;
  color: #111827;
}

.section-browser-header h2 svg {
  color: #8b5cf6;
}

.close-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: transparent;
  border: none;
  border-radius: 6px;
  color: #6b7280;
  cursor: pointer;
  transition: all 0.2s;
}

.close-btn:hover {
  background: #f3f4f6;
  color: #111827;
}

/* Search */
.section-browser-search {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 24px;
  border-bottom: 1px solid #e5e7eb;
}

.section-browser-search svg {
  color: #9ca3af;
  flex-shrink: 0;
}

.section-browser-search input {
  flex: 1;
  border: none;
  outline: none;
  font-size: 15px;
  color: #111827;
}

.section-browser-search input::placeholder {
  color: #9ca3af;
}

/* Breadcrumb */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  background: #f9fafb;
  border-bottom: 1px solid #e5e7eb;
  font-size: 14px;
  color: #6b7280;
}

.breadcrumb-btn {
  background: none;
  border: none;
  color: #8b5cf6;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 4px;
  transition: all 0.2s;
}

.breadcrumb-btn:hover {
  background: #ede9fe;
}

/* Content */
.section-browser-content {
  flex: 1;
  overflow-y: auto;
  padding: 16px 24px;
}

.loading-state,
.error-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 48px 24px;
  color: #6b7280;
  text-align: center;
}

.loading-state svg.spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.error-state {
  color: #ef4444;
}

.empty-state svg {
  color: #d1d5db;
}

.empty-state p {
  font-size: 14px;
  margin: 0;
}

/* Document List */
.document-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.document-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  text-align: left;
  width: 100%;
}

.document-item:hover {
  background: #f9fafb;
  border-color: #8b5cf6;
  transform: translateX(4px);
}

.doc-icon {
  flex-shrink: 0;
  color: #8b5cf6;
}

.doc-info {
  flex: 1;
  min-width: 0;
}

.doc-title {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #111827;
  margin-bottom: 4px;
}

.doc-meta {
  display: block;
  font-size: 13px;
  color: #6b7280;
}

.arrow {
  flex-shrink: 0;
  color: #9ca3af;
}

/* Section List */
.section-list {
  display: flex;
  flex-direction: column;
}

.section-item-wrapper {
  border-bottom: 1px solid #f3f4f6;
}

.section-item-wrapper:last-child {
  border-bottom: none;
}

.section-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px;
  background: white;
  border: none;
  cursor: pointer;
  transition: all 0.2s;
  text-align: left;
  width: 100%;
  border-radius: 6px;
}

.section-item:hover {
  background: #f9fafb;
}

.section-item:hover .section-arrow {
  color: #8b5cf6;
  transform: translateX(2px);
}

.section-arrow {
  flex-shrink: 0;
  color: #d1d5db;
  transition: all 0.2s;
}

.section-icon {
  flex-shrink: 0;
  color: #8b5cf6;
}

.section-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.section-title {
  font-size: 14px;
  font-weight: 500;
  color: #111827;
}

.section-id {
  font-size: 12px;
  color: #9ca3af;
  font-family: 'Monaco', 'Courier New', monospace;
}

.subsections {
  margin-left: 20px;
}

/* Footer */
.section-browser-footer {
  padding: 16px 24px;
  border-top: 1px solid #e5e7eb;
  background: #f9fafb;
}

.hint {
  margin: 0;
  font-size: 13px;
  color: #6b7280;
  text-align: center;
}

/* Responsive */
@media (max-width: 768px) {
  .section-browser-modal {
    width: 95%;
    max-height: 90vh;
  }

  .section-browser-header h2 {
    font-size: 18px;
  }

  .section-browser-search,
  .breadcrumb,
  .section-browser-content,
  .section-browser-footer {
    padding-left: 16px;
    padding-right: 16px;
  }
}
